generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  LAWYER
  CLIENT
}

enum CaseStatus {
  INTAKE
  ANALYSIS
  PREPARATION
  FILED
  AWAITING
  COMPLETED
}

enum CaseCategory {
  FAMILY
  CIVIL
  COMMERCIAL
  CRIMINAL
  MIGRATION
  REALESTATE
  LABOR
  OTHER
}

enum Urgency {
  URGENT
  WEEK
  NORMAL
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentType {
  FREE
  CONSULT
  ANALYSIS
}

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE
  READY
  ARCHIVED
}

enum NotificationType {
  CASE_UPDATE
  APPOINTMENT_REMINDER
  DOCUMENT_READY
  MESSAGE
  SYSTEM
  NEW_CLIENT
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TokenType {
  PUBLIC_LAWYER
  PRIVATE_CASE
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PRO
  BUREAU
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum IntakeStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// --- Multi-tenancy ---

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       OrganizationMember[]
  inviteTokens  InviteToken[]
  subscription  Subscription?
  usageCounters UsageCounter[]
  cases         Case[]
  appointments  Appointment[]
  documents     Document[]
  intakes       IntakeSubmission[]
  notifications Notification[]

  @@index([slug])
}

model OrganizationMember {
  id     String       @id @default(uuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   OrgRole      @default(MEMBER)

  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// --- Invite Tokens ---

model InviteToken {
  id         String        @id @default(uuid())
  orgId      String
  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lawyerId   String
  lawyer     LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  token      String        @unique
  tokenType  TokenType
  caseId     String?
  expiresAt  DateTime?
  isActive   Boolean       @default(true)
  usageCount Int           @default(0)
  maxUses    Int?

  createdAt DateTime @default(now())

  clientProfiles ClientProfile[]

  @@index([token])
  @@index([orgId])
  @@index([lawyerId])
}

// --- Subscription & Usage ---

model Subscription {
  id              String             @id @default(uuid())
  orgId           String             @unique
  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan   @default(TRIAL)
  status          SubscriptionStatus @default(TRIAL)
  startedAt       DateTime           @default(now())
  expiresAt       DateTime?
  trialUsed       Boolean            @default(false)
  paymentProvider String?
  paymentId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
}

model UsageCounter {
  id           String       @id @default(uuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  period       String
  clientsCount Int          @default(0)
  casesCount   Int          @default(0)
  aiDocsCount  Int          @default(0)
  uploadsCount Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, period])
  @@index([orgId])
}

// --- Core Entities ---

model User {
  id         String  @id @default(uuid())
  email      String? @unique
  password   String?
  role       Role
  name       String
  phone      String?
  city       String?
  avatarUrl  String?
  telegramId BigInt? @unique
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lawyerProfile       LawyerProfile?
  clientProfile       ClientProfile?
  notifications       Notification[]
  telegramIdentity    TelegramIdentity?
  uploads             Upload[]
  organizationMembers OrganizationMember[]
  sentMessages        Message[]            @relation("sender")

  @@index([email])
  @@index([role])
  @@index([telegramId])
}

model LawyerProfile {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId       String?
  licenseNo   String?
  specialties CaseCategory[]
  bio         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases        Case[]
  appointments Appointment[]
  timeLogs     TimeLog[]
  inviteTokens InviteToken[]

  @@index([userId])
  @@index([orgId])
}

model ClientProfile {
  id            String       @id @default(uuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId         String?
  accessCode    String       @unique
  taxId         String?
  sourceTokenId String?
  sourceToken   InviteToken? @relation(fields: [sourceTokenId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases        Case[]
  appointments Appointment[]
  intakeForm   IntakeSubmission?

  @@index([userId])
  @@index([accessCode])
  @@index([orgId])
}

model IntakeSubmission {
  id          String        @id @default(uuid())
  clientId    String        @unique
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  category    CaseCategory
  urgency     Urgency
  description String
  city        String?
  fileName    String?
  status      IntakeStatus  @default(PENDING)
  leadScore   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([orgId])
  @@index([status])
}

model Case {
  id          String       @id @default(uuid())
  caseNumber  String       @unique
  title       String
  category    CaseCategory
  status      CaseStatus   @default(INTAKE)
  urgency     Urgency      @default(NORMAL)
  description String?
  courtName   String?
  courtDate   DateTime?
  courtRoom   String?
  nextAction  String?
  nextDate    DateTime?

  lawyerId String
  lawyer   LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Restrict)
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Restrict)
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  documents    Document[]
  appointments Appointment[]
  timeLogs     TimeLog[]
  messages     Message[]
  checklist    ChecklistItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([caseNumber])
  @@index([lawyerId])
  @@index([clientId])
  @@index([status])
  @@index([orgId])
}

model Document {
  id      String         @id @default(uuid())
  name    String
  status  DocumentStatus @default(DRAFT)
  type    String?
  content String?
  size    String?

  caseId   String
  case     Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  uploadId String?       @unique
  upload   Upload?       @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([caseId])
  @@index([status])
  @@index([orgId])
}

model Upload {
  id           String @id @default(uuid())
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  document Document?

  createdAt DateTime @default(now())

  @@index([uploadedById])
}

model Appointment {
  id        String            @id @default(uuid())
  refNumber String            @unique
  type      AppointmentType
  status    AppointmentStatus @default(PENDING)
  date      DateTime
  duration  Int
  price     Int
  notes     String?

  lawyerId String
  lawyer   LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Restrict)
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Restrict)
  caseId   String?
  case     Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  reminders AppointmentReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lawyerId])
  @@index([clientId])
  @@index([date])
  @@index([status])
  @@index([orgId])
}

model AppointmentReminder {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  timing        String
  enabled       Boolean     @default(true)
  sentAt        DateTime?

  createdAt DateTime @default(now())

  @@unique([appointmentId, timing])
}

model TimeLog {
  id          String        @id @default(uuid())
  lawyerId    String
  lawyer      LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  description String
  minutes     Int
  date        DateTime      @default(now())
  billable    Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lawyerId])
  @@index([caseId])
}

model Message {
  id       String  @id @default(uuid())
  caseId   String
  case     Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  senderId String
  sender   User    @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  text     String
  isRead   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([senderId])
}

model ChecklistItem {
  id     String  @id @default(uuid())
  caseId String
  case   Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  text   String
  done   Boolean @default(false)
  order  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
}

model Notification {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId        String?
  org          Organization?    @relation(fields: [orgId], references: [id], onDelete: SetNull)
  type         NotificationType
  title        String
  body         String
  isRead       Boolean          @default(false)
  link         String?
  telegramSent Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([orgId])
}

model TelegramIdentity {
  id               String  @id @default(uuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramId       BigInt  @unique
  telegramUsername String?
  chatId           BigInt
  botType          String
  isVerified       Boolean @default(false)

  linkedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([telegramId])
  @@index([userId])
}
